# AI配置 - 通义千问
QWEN_API_KEY=sk-your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 管理员配置
ADMIN_PASSWORD=admin123456
ADMIN_SESSION_SECRET=inknowing_session_secret_2026
SESSION_SECRET=inknowing_user_session_2026
SESSION_MAX_AGE=86400

# ChromaDB配置
CHROMA_DB_PATH=/app/data/vectors
CHROMA_COLLECTION_NAME=inknowing_docs

# 数据库配置
DATABASE_PATH=/app/data/db/inknowing.db

# 文档存储配置
DOCUMENTS_PATH=/app/data/documents

NODE_ENV=production
PORT=3000
