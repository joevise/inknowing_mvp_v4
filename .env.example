# AI配置 - 通义千问
# 重要：QWEN_API_BASE必须使用compatible-mode的URL以兼容OpenAI SDK
QWEN_API_KEY=sk-your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 或使用OpenAI兼容接口
# OPENAI_API_KEY=your_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-3.5-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 管理员配置
ADMIN_PASSWORD=admin123456
ADMIN_SESSION_SECRET=your_random_session_secret_here

# 用户Session配置
SESSION_SECRET=your_random_session_secret_for_users_here
SESSION_MAX_AGE=86400

# ChromaDB配置
CHROMA_DB_PATH=./data/vectors
CHROMA_COLLECTION_NAME=inknowing_docs

# 数据库配置
DATABASE_PATH=./data/db/inknowing.db

# 文档存储配置
DOCUMENTS_PATH=./data/documents

# 开发配置
NODE_ENV=development
PORT=3000

# 日志级别
LOG_LEVEL=debug