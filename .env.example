# AI配置 - 通义千问
# 重要：QWEN_API_BASE必须使用compatible-mode的URL以兼容OpenAI SDK
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 或使用OpenAI兼容接口
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-3.5-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 管理员配置
ADMIN_PASSWORD=your_admin_password_here
ADMIN_SESSION_SECRET=your_random_secret_here

# 用户Session配置
SESSION_SECRET=your_random_secret_here
SESSION_MAX_AGE=86400

# ===== 数据库配置 (PostgreSQL) =====
# app 容器经 docker 网络用服务名 postgres 访问;迁移脚本/宿主机用 127.0.0.1:5433
# 容器内连接串(写进 .env 供 app 读取):
DATABASE_URL=postgresql://inknowing:your_pg_password_here@postgres:5432/inknowing
# postgres 服务密码(docker-compose 变量替换用,务必与 DATABASE_URL 中一致):
POSTGRES_PASSWORD=your_pg_password_here
# 宿主机直连(迁移脚本 npx tsx 时用):
# DATABASE_URL=postgresql://inknowing:your_pg_password_here@127.0.0.1:5433/inknowing

# ChromaDB配置 (当前生产未启用向量检索,documents=0)
CHROMA_DB_PATH=./data/vectors
CHROMA_COLLECTION_NAME=inknowing_docs

# 文档存储配置
DOCUMENTS_PATH=./data/documents

# 开发配置
NODE_ENV=development
PORT=3000

# 日志级别
LOG_LEVEL=debug

# ===== 微信支付 (API v3 Native 扫码) =====
# 全部留空则不启用微信支付
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_NOTIFY_URL=https://inknowing.ai/api/payment/webhook/wechat
